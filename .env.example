# Syncer app
API_BASE_URL=http://localhost:3000
# Optional direct lockfile URL; if set, API_BASE_URL is not required
# PROFILE_LOCK_URL=https://cdn.example.com/mvl/profile.lock.json
SERVER_ID=mvl
LAUNCHER_UPDATE_ENDPOINT=https://github.com/isaacismaelx14/mc-client-center/releases/latest/download/latest.json
# Required for signed launcher self-updates (public key generated via `tauri signer generate`).
# LAUNCHER_UPDATE_PUBKEY=...
# Required outside localhost when API profile/lock signature verification is enabled.
# PROFILE_SIGNATURE_PUBLIC_KEY=...
# Optional: enables hidden devtools unlock in packaged app via Ctrl/Cmd+Alt+Shift+D.
# DEVTOOLS_SECRET_COMMAND=replace-with-strong-secret-command

# API
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mvl_syncer
CORS_ORIGIN=http://localhost:1420
PORT=3000
# Required for secure launcher device enrollment in production/public deployments.
# Use a strong random value and keep it secret.
# LAUNCHER_INSTALL_CODE=replace-with-long-random-secret
FANCYMENU_SANDBOX_URL=http://localhost:3210
FANCYMENU_SANDBOX_API_KEY=sandbox-dev-key
