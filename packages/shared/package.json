{
  "name": "@minerelay/shared",
  "version": "0.2.2",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "echo 'no lint configured for shared'",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "vitest": "4.0.18"
  }
}
