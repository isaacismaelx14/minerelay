{
  "name": "mc-client-center",
  "private": true,
  "version": "0.1.0-beta.31",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:staged": "node scripts/lint-staged.mjs",
    "lint:affected": "turbo run lint --affected",
    "format:check": "prettier --check .",
    "format:check-staged": "node scripts/check-staged-format.mjs",
    "format": "prettier --write .",
    "typecheck": "turbo run typecheck",
    "typecheck:affected": "turbo run typecheck --affected",
    "test:affected": "turbo run test --affected",
    "build:affected": "turbo run build --affected",
    "clean": "turbo run clean && rm -rf node_modules",
    "release:target": "pnpm --filter @minerelay/infra-scripts release:target",
    "release:auto": "pnpm release:target -- --target auto",
    "release:api": "pnpm release:target -- --target api",
    "release:admin": "pnpm release:target -- --target admin",
    "release:launcher": "pnpm release:target -- --target launcher",
    "release:shared": "pnpm release:target -- --target shared",
    "prepare": "husky",
    "commitmsg:check": "node scripts/validate-commit-msg.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  }
}
