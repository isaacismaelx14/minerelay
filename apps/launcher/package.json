{
  "name": "@minerelay/launcher",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "dev": "npm run tauri:dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features devtools",
    "tauri:build": "tauri build",
    "tauri:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "vite:build": "vite build",
    "vite:dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests && npm run tauri:test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@minerelay/shared": "workspace:*",
    "@minerelay/ui": "workspace:*",
    "@tailwindcss/vite": "4.2.1",
    "@tauri-apps/api": "2.10.1",
    "clsx": "2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "9.39.3",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "globals": "17.4.0",
    "terser": "5.46.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
