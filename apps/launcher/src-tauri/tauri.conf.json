{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MineRelay Client",
  "version": "0.6.2",
  "identifier": "com.minerelay.launcher",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MineRelay",
        "width": 420,
        "height": 720,
        "decorations": true,
        "resizable": false,
        "minWidth": 390,
        "minHeight": 620,
        "visible": false
      },
      {
        "label": "setup",
        "title": "MineRelay Setup",
        "width": 1160,
        "height": 760,
        "resizable": true,
        "minWidth": 920,
        "minHeight": 620,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; img-src 'self' asset: https: http://localhost:* http://127.0.0.1:* data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["minerelay"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NzEwRTNCOUJGMERCMzYKUldRMjIvQ2JPdzV4R0FPaW12NnZPOU1oNFRNVStKYlVFTS9XbU0yd0tDTTkrQUNrazBHT2pEeW0K"
    }
  }
}
