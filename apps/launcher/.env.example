PROFILE_SIGNATURE_PUBLIC_KEY=base64-public-key
DEVTOOLS_SECRET_COMMAND=optional-dev-only-secret
LAUNCHER_INSTALL_CODE=optional-install-enrollment-code
SERVER_ID=mvl
LAUNCHER_UPDATE_ENDPOINT=https://github.com/isaacismaelx14/mc-client-center/releases/latest/download/latest.json
LAUNCHER_UPDATE_PUBKEY=minisign-public-key
