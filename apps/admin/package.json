{
  "name": "@minerelay/admin",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node ./scripts/run-vinext.mjs dev --port 3001",
    "build": "node ./scripts/run-vinext.mjs build",
    "start": "node ./scripts/run-vinext.mjs start --port 3001",
    "deploy": "node ./scripts/run-vinext.mjs deploy",
    "lint": "node ./scripts/run-vinext.mjs lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next dist .wrangler"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-server-dom-webpack": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.26.1",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-rsc": "0.5.21",
    "eslint": "10.0.3",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "tailwindcss": "4.2.1",
    "typescript": "5",
    "vinext": "0.0.24",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "wrangler": "4.71.0"
  }
}
