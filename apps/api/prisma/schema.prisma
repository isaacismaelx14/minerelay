generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Server {
  id                      String           @id
  name                    String
  address                 String
  allowedMinecraftVersions String[]
  fancyMenuEnabled        Boolean          @default(false)
  fancyMenuSettings       Json?
  profileId               String
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  versions                ProfileVersion[]
}

model ProfileVersion {
  id                   Int      @id @default(autoincrement())
  serverId             String
  profileId            String
  version              Int
  releaseVersion       String   @default("1.0.0")
  minecraftVersion     String
  loader               String
  loaderVersion        String
  defaultServerName    String
  defaultServerAddress String
  fancyMenuEnabled     Boolean  @default(false)
  fancyMenuSettings    Json?
  lockUrl              String
  signature            String?
  summaryAdd           Int      @default(0)
  summaryRemove        Int      @default(0)
  summaryUpdate        Int      @default(0)
  summaryKeep          Int      @default(0)
  lockJson             Json
  createdAt            DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, version])
  @@index([profileId, version])
}

model AdminCredential {
  id                 String   @id
  passwordHash       String
  passwordCiphertext String
  passwordIv         String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AdminSession {
  id               String    @id
  accessTokenHash  String
  refreshTokenHash String
  expiresAt        DateTime
  refreshExpiresAt DateTime
  revokedAt        DateTime?
  ip               String?
  userAgent        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([expiresAt])
  @@index([refreshExpiresAt])
}

model AppSetting {
  id                         String   @id
  supportedMinecraftVersions String[]
  supportedPlatforms         String[]
  releaseMajor               Int      @default(1)
  releaseMinor               Int      @default(0)
  releasePatch               Int      @default(0)
  publishDraft               Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ExarotonIntegration {
  id                    String   @id
  apiKeyCiphertext      String
  apiKeyIv              String
  apiKeyAuthTag         String
  accountName           String?
  accountEmail          String?
  selectedServerId      String?
  selectedServerName    String?
  selectedServerAddress String?
  modsSyncEnabled       Boolean  @default(true)
  playerCanViewStatus   Boolean  @default(true)
  playerCanViewOnlinePlayers Boolean  @default(true)
  playerCanModifyStatus Boolean  @default(false)
  playerCanStartServer  Boolean  @default(false)
  playerCanStopServer   Boolean  @default(false)
  playerCanRestartServer Boolean @default(false)
  connectedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model LauncherTrustedDevice {
  id            String   @id
  installationId String  @unique
  publicKeyHash String
  publicKeyBase64 String
  deviceFingerprintHash String
  appVersion    String?
  platform      String?
  lastSeenAt    DateTime?
  trustedAt     DateTime @default(now())
  rotatedAt     DateTime?
  revokedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([revokedAt])
  @@index([publicKeyHash])
  @@index([deviceFingerprintHash])
}

model LauncherPairingClaim {
  id                        String   @id
  tokenHash                 String   @unique
  codeHash                  String   @unique
  expiresAt                 DateTime
  consumedAt                DateTime?
  revokedAt                 DateTime?
  issuedAt                  DateTime @default(now())
  issuedBy                  String?
  consumedByInstallationId  String?
  consumedByDeviceHash      String?

  @@index([expiresAt])
  @@index([revokedAt])
  @@index([consumedAt])
}

model LauncherChallenge {
  id         String   @id
  nonce      String
  issuedAt   DateTime @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([expiresAt])
  @@index([consumedAt])
}

model LauncherSession {
  id              String   @id
  tokenHash       String   @unique
  tokenId         String   @unique
  installationId  String
  publicKeyBase64 String
  userAgentHash   String
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  nonces LauncherSessionNonce[]

  @@index([expiresAt])
  @@index([revokedAt])
  @@index([installationId])
}

model LauncherSessionNonce {
  id        String   @id
  sessionId String
  nonce     String
  expiresAt DateTime

  session LauncherSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, nonce])
  @@index([expiresAt])
}
