DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mvl_syncer
CORS_ORIGIN=http://localhost:1420
PORT=3000
SERVER_ID=mvl
LOCK_URL=http://localhost:3000/v1/locks/mvl-main/2
# Optional. If omitted, defaults to ~/.mss-client/artifacts
# ARTIFACTS_DIR=/absolute/path/to/artifacts
# Optional backend for artifact storage. `local` (default) or `s3`.
# ASSETS_STORAGE_BACKEND=s3
# Cloudflare S3-compatible object storage (R2) settings.
# ASSETS_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# ASSETS_S3_BUCKET=your-bucket-name
# ASSETS_S3_ACCESS_KEY_ID=...
# ASSETS_S3_SECRET_ACCESS_KEY=...
# ASSETS_S3_REGION=auto
# ASSETS_S3_FORCE_PATH_STYLE=true
# Optional key prefix inside bucket. Defaults:
# - production: assets
# - non-production: dev/assets
# ASSETS_KEY_PREFIX=dev/assets
# Optional public CDN base for object URLs (recommended for R2 custom domains)
# ASSETS_PUBLIC_BASE_URL=https://cdn.invitefeed.com
# Optional. Public API base URL used to generate lock/artifact links (useful behind tunnels/proxies).
# PUBLIC_BASE_URL=https://your-domain-or-tunnel.example
ADMIN_INITIAL_PASSWORD=secret
# Base64 value for a 32-byte seed or 64-byte Ed25519 secret key.
# Optional in development, required in production.
# PROFILE_SIGNING_SECRET_KEY_BASE64=
# Optional identifier embedded in responses.
PROFILE_SIGNING_KEY_ID=mvl-k1
ADMIN_ACCESS_TOKEN_TTL_MINUTES=15
ADMIN_REFRESH_TOKEN_TTL_DAYS=14
ADMIN_COOKIE_SECURE=false
ENABLE_SWAGGER=true
# Required for secure launcher device enrollment in production/public deployments.
# Use a strong random value and keep it secret.
# LAUNCHER_INSTALL_CODE=replace-with-long-random-secret
FANCYMENU_SANDBOX_URL=http://localhost:3210
FANCYMENU_SANDBOX_API_KEY=sandbox-dev-key
FANCYMENU_SANDBOX_TIMEOUT_MS=10000
FANCYMENU_PREVIEW_TTL_SECONDS=1800
