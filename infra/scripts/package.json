{
  "name": "@mss/infra-scripts",
  "version": "0.1.0-beta.31",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/publish-profile.ts src/compute-sha256.ts src/release-notes.ts src/generate-updater-manifest.ts src/verify-release-updater-assets.ts src/semantic-release.ts --format esm --dts --clean",
    "publish-profile": "tsx src/publish-profile.ts",
    "sha256": "tsx src/compute-sha256.ts",
    "release-notes": "tsx src/release-notes.ts",
    "release:target": "tsx src/semantic-release.ts",
    "manifest:generate": "tsx src/generate-updater-manifest.ts",
    "manifest:test": "tsx src/test-generate-updater-manifest.ts",
    "updater:verify": "tsx src/verify-release-updater-assets.ts",
    "lint": "echo 'no lint configured for infra scripts'",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mss/shared": "workspace:*",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
